{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:tray:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://*:*" }, { "url": "https://*:*" }]
    },
    "store:default",
    "window-state:default"
  ]
}
